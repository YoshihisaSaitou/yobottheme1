                    "fontSize": "1.125rem",
                    "fontWeight": "bold"
                },
                "spacing": {
                    "margin": {
                        "top": "0",
                        "bottom": "1rem"
                    }
                }
            },
            "h6": {
                "typography": {
                    "fontSize": "1.0rem",
                    "fontWeight": "bold"
                },
                "spacing": {
                    "margin": {
                        "top": "0",
