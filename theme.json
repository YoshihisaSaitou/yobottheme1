{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "custom": {
            "default": {
                "font-size": "1.0rem"
            }
        },
        "color": {
            "link": true,
            "palette": [
                {
                    "color": "#0B0098",
                    "name": "Main1",
                    "slug": "main-1"
                },
                {
                    "color": "rgba(11, 0, 152, 0.6)",
                    "name": "Main1 opacity",
                    "slug": "main-1-opacity"
                },
                {
                    "color": "#43B7D9",
                    "name": "Main2",
                    "slug": "main-2"
                },
                {
                    "color": "#7CC9D8",
                    "name": "Main3",
                    "slug": "main-3"
                },
                {
                    "color": "#DBECEF",
                    "name": "Main4",
                    "slug": "main-4"
                },
                {
                    "color": "#333333",
                    "name": "Default text",
                    "slug": "default-text"
                },
                {
                    "color": "#D0D0D0",
                    "name": "Border 1",
                    "slug": "border-1"
                }
            ],
            "gradients": [
                {
                    "gradient": "linear-gradient(to right, var(--wp--preset--color--main-2) 50%, var(--wp--preset--color--main-3) 50%)",
                    "name": "Main2 50% to Main3 50%",
                    "slug": "main-2-half-to-main-3-half"
                },
                {
                    "gradient": "linear-gradient(to right, var(--wp--preset--color--main-1) 80px, var(--wp--preset--color--main-2) 0px)",
                    "name": "Main1 80px to Main2",
                    "slug": "main-1-80-px-to-main-2"
                }
            ]
        },
        "layout": {
            "contentSize": "960px",
            "wideSize": "1440px"
        },
        "useRootPaddingAwareAlignments": true,
        "spacing": {
            "blockGap": true,
            "margin": true,
            "padding": true,
            "spacingScale": {
                "steps": 10
            }
        },
        "typography": {
            "lineHeight": true,
            "fluid": true,
            "fontFamilies": [
                {
                    "fontFamily": "\"Noto Sans JP\", sans-serif",
                    "slug": "default"
                }
            ],
            "fontSizes": [
                {
                    "name": "Small",
                    "size": "0.875rem",
                    "slug": "small"
                },
                {
                    "name": "Medium",
                    "size": "1rem",
                    "slug": "medium"
                },
                {
                    "name": "Large",
                    "size": "1.125rem",
                    "slug": "large"
                },
                {
                    "name": "Extra Large",
                    "size": "1.25rem",
                    "slug": "x-large"
                },
                {
                    "name": "Extra Extra Large",
                    "size": "1.375rem",
                    "slug": "xx-large"
                }
            ],
            "writingMode": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        }
    },
    "styles": {
        "spacing": {
            "blockGap": "0.5rem",
            "padding": {
                "top": "0",
                "bottom": "0",
                "left": "1rem",
                "right": "1rem"
            }
        },
        "elements": {
            "h1": {
                "typography": {
                    "fontSize": "2rem",
                    "fontWeight": "bold",
                    "textAlign": "center"
                },
                "spacing": {
                    "margin": {
                        "top": "1rem",
                        "bottom": "0.5rem"
                    }
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "1.5rem",
                    "fontWeight": "bold"
                },
                "border": {
                    "bottom": {
                        "style": "solid",
                        "width": "0.25rem",
                        "color": "var(--wp--preset--color--main-1)"
                    }
                },
                "spacing": {
                    "margin": {
                        "top": "0",
                        "bottom": "1rem"
                    },
                    "padding": {
                        "bottom": "0"
                    }
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "1.5rem",
                    "fontWeight": "bold"
                },
                "border": {
                    "left": {
                        "style": "solid",
                        "width": "0.25rem",
                        "color": "var(--wp--preset--color--main-1)"
                    }
                },
                "spacing": {
                    "margin": {
                        "top": "0",
                        "bottom": "1rem"
                    },
                    "padding": {
                        "left": "0.25rem"
                    }
                }
            },
            "h4": {
