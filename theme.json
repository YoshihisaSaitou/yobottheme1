            "link": {
                "typography": {
                    "textDecoration": "none"
                },
                ":hover": {
                    "typography": {
                        "textDecoration": "none"
                    }
                },
                ":visited": {
                    "typography": {
                        "textDecoration": "none"
                    }
                },
                "color": {
                    "text": "var(--wp--preset--color--main-1)"
                }
            },
            "button": {
                "typography": {
                    "fontSize": "1rem"
                },
                "color": {
                    "background": "var(--wp--preset--color--main-1)",
                    "text": "#fff"
                },
                "spacing": {
                    "padding": {
                        "left": "1.5rem",
                        "right": "2rem"
                    }
                },
                "border": {
                    "radius": "0rem"
                },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--main-1-opacity)"
                    }
                }
            }
